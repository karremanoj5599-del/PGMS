{
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/iclock/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api|iclock).*)",
      "destination": "/index.html"
    }
  ]
}
